{
  "source": ["src/styles/style-dictionary/tokens/colors.json"],
  "platforms": {
    "js": {
      "buildPath": "src/styles/colors/",
      "files": [
        {
          "format": "custom-js-format-colors",
          "destination": "colors.ts"
        }
      ]
    },
    "css": {
      "buildPath": "src/styles/colors/",
      "files": [
        {
          "format": "css-custom-properties",
          "destination": "colors.css",
          "options": {
            "category": "colors"
          }
        }
      ]
    }
  }
}
