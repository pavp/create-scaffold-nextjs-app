{
  "source": ["src/styles/style-dictionary/tokens/shadows.json"],
  "platforms": {
    "css": {
      "buildPath": "src/styles/shadows/",
      "files": [
        {
          "format": "css-custom-properties",
          "destination": "shadows.css",
          "options": {
            "category": "shadows"
          }
        }
      ]
    },
    "js": {
      "buildPath": "src/styles/shadows/",
      "files": [
        {
          "format": "custom-js-format-generic",
          "destination": "shadows.ts",
          "options": {
            "exportName": "shadows"
          }
        }
      ]
    }
  }
}
