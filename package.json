{
  "name": "create-nextlane-app",
  "version": "0.0.0",
  "private": false,
  "description": "Official CLI tool to bootstrap modern frontend applications with Nextlane's template",
  "keywords": [
    "nextlane",
    "react",
    "nextjs",
    "template",
    "cli",
    "bootstrap"
  ],
  "homepage": "https://github.com/nxl-engineering/shared-create-nextlane-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/nxl-engineering/shared-create-nextlane-app.git"
  },
  "bugs": {
    "url": "https://github.com/nxl-engineering/shared-create-nextlane-app/issues"
  },
  "license": "UNLICENSED",
  "bin": {
    "create-nextlane-app": "./bin/create-nextlane-app.js"
  },
  "scripts": {
    "dev": "yarn build-dictionary && next dev --turbopack",
    "build": "yarn build-dictionary && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky",
    "build-dictionary": "node ./src/styles/style-dictionary/build.mjs",
    "create-project": "node ./scripts/create-project.js",
    "test-cli": "node ./test-cli-automated.js",
    "test-cli-interactive": "node ./test-interactive.js",
    "commit": "git-cz",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "pre-commit": "lint-staged",
    "pre-push": "npm run test && npm run build",
    "validate-commits": "commitlint --from origin/main --to HEAD --verbose"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^4.1.2",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@mui/material-nextjs": "^7.2.0",
    "@mui/system": "^7.2.0",
    "@mui/x-date-pickers-pro": "^8.8.0",
    "@mui/x-license": "^8.8.0",
    "@reduxjs/toolkit": "^2.6.1",
    "@screeb/sdk-browser": "^0.1.16",
    "async-mutex": "^0.5.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.4",
    "js-cookie": "^3.0.5",
    "lint-staged": "^15.2.7",
    "mixpanel-browser": "^2.53.0",
    "next": "15.4.1",
    "next-intl": "4.3.4",
    "react": "19.1.0",
    "react-color": "^2.19.3",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.52.1",
    "react-redux": "^9.2.0",
    "redux-logger": "^3.0.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@faker-js/faker": "^9.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.7",
    "@testing-library/react": "^16.2.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.12",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.15",
    "@types/mixpanel-browser": "^2.49.1",
    "@types/node": "^20.14.11",
    "@types/react": "19.0.10",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "19.0.4",
    "@types/redux-logger": "^3.0.13",
    "@typescript-eslint/parser": "^8.26.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.4.1",
    "eslint-plugin-check-file": "^3.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "prettier": "^3.5.3",
    "sass": "^1.77.8",
    "semantic-release": "^24.2.6",
    "style-dictionary": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "whatwg-fetch": "^3.6.20"
  },
  "resolutions": {
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "glob": "^10.0.0",
    "rimraf": "^5.0.0"
  },
  "overrides": {
    "@mui/x-license-pro": "^8.8.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "types": {
        "feat": {
          "description": "A new feature",
          "title": "Features"
        },
        "fix": {
          "description": "A bug fix",
          "title": "Bug Fixes"
        },
        "docs": {
          "description": "Documentation only changes",
          "title": "Documentation"
        },
        "chore": {
          "description": "Other changes that don't modify src or test files",
          "title": "Chores"
        },
        "perf": {
          "description": "A code change that improves performance",
          "title": "Performance"
        },
        "refactor": {
          "description": "A code change that neither fixes a bug nor adds a feature",
          "title": "Code Refactoring"
        },
        "test": {
          "description": "Adding missing tests or correcting existing tests",
          "title": "Tests"
        },
        "hotfix": {
          "description": "A critical bug fix that needs immediate attention",
          "title": "Hotfixes"
        }
      },
      "scopes": [
        "cli",
        "template",
        "nextjs",
        "react",
        "styles",
        "scripts",
        "config",
        "dependencies",
        "husky",
        "lint"
      ]
    }
  }
}
