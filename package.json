{
  "name": "create-scaffold-nextjs-app",
  "version": "1.0.7",
  "private": false,
  "description": "Official CLI tool to bootstrap modern frontend applications with Scaffold's template",
  "keywords": [
    "scaffold",
    "react",
    "nextjs",
    "template",
    "cli",
    "bootstrap"
  ],
  "homepage": "https://github.com/pavp/create-scaffold-nextjs-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/pavp/create-scaffold-nextjs-app.git"
  },
  "bugs": {
    "url": "https://github.com/pavp/create-scaffold-nextjs-app/issues"
  },
  "license": "UNLICENSED",
  "bin": {
    "create-scaffold-app": "./bin/create-scaffold-app.js"
  },
  "scripts": {
    "dev": "yarn build:dictionary && next dev --turbopack",
    "build": "yarn build:dictionary && next build",
    "start": "next start",
    "lint": "eslint . && yarn lint:styles",
    "lint:fix": "eslint . --fix && yarn lint:styles:fix",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
    "lint:styles:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:changed": "jest --changedSince=origin/main --coverage --coverageReporters=text-summary --passWithNoTests",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "prepare": "node -e \"if(process.env.CI !== 'true') require('child_process').execSync('husky', {stdio: 'inherit'})\"",
    "build:dictionary": "node ./src/styles/style-dictionary/build.mjs",
    "create:project": "node ./scripts/create-project.js",
    "test:cli": "node ./test-cli-automated.js",
    "check:drift": "node ./scripts/check-drift.js",
    "test:cli:interactive": "node ./test-interactive.js",
    "commit": "git-cz",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "pre:commit": "lint-staged",
    "pre:push": "yarn test && yarn build",
    "validate:commits": "commitlint --from origin/main --to HEAD --verbose",
    "validate:branch": "node scripts/validate-branch-name.js"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/material-nextjs": "^7.3.10",
    "@mui/system": "^7.3.11",
    "@mui/x-date-pickers-pro": "^8.28.5",
    "@mui/x-license": "^8.26.0",
    "@tanstack/react-query": "^5.100.10",
    "async-mutex": "^0.5.0",
    "axios": "^1.16.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "immer": "^11.1.8",
    "js-cookie": "^3.0.5",
    "next": "15.5.18",
    "next-intl": "4.3.4",
    "react": "19.2.6",
    "react-color": "^2.19.3",
    "react-dom": "19.2.6",
    "react-hook-form": "7.60.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "9.9.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "4.17.24",
    "@types/node": "^25.7.0",
    "@types/react": "19.2.14",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.59.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "17.0.5",
    "postcss": "^8.5.14",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "semantic-release": "25.0.3",
    "style-dictionary": "^5.4.0",
    "stylelint": "^17.11.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "whatwg-fetch": "^3.6.20"
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "glob": "^13.0.0",
    "handlebars": "^4.7.9",
    "rimraf": "^5.0.0"
  },
  "overrides": {
    "@mui/x-license-pro": "^8.8.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "types": {
        "feat": {
          "description": "A new feature",
          "title": "Features"
        },
        "fix": {
          "description": "A bug fix",
          "title": "Bug Fixes"
        },
        "docs": {
          "description": "Documentation only changes",
          "title": "Documentation"
        },
        "chore": {
          "description": "Other changes that don't modify src or test files",
          "title": "Chores"
        },
        "perf": {
          "description": "A code change that improves performance",
          "title": "Performance"
        },
        "refactor": {
          "description": "A code change that neither fixes a bug nor adds a feature",
          "title": "Code Refactoring"
        },
        "test": {
          "description": "Adding missing tests or correcting existing tests",
          "title": "Tests"
        },
        "hotfix": {
          "description": "A critical bug fix that needs immediate attention",
          "title": "Hotfixes"
        }
      },
      "scopes": [
        "cli",
        "template",
        "nextjs",
        "react",
        "styles",
        "scripts",
        "config",
        "dependencies",
        "husky",
        "lint"
      ]
    }
  },
  "files": [
    "bin/",
    "template/",
    "scripts/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
